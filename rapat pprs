<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Hadir Wali Santri</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background-color: #f0f2f5; margin: 0; padding: 15px; }
        .kop-surat { text-align: center; background: white; padding: 10px; border-bottom: 5px double #000; max-width: 600px; margin: auto; }
        .kop-surat img { max-width: 100%; height: auto; display: block; margin: 0 auto; }
        
        .container { max-width: 600px; margin: auto; background: white; padding: 25px; border-radius: 0 0 12px 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); box-sizing: border-box; }
        .btn-group { display: flex; gap: 10px; margin-bottom: 20px; }
        .btn-type { flex: 1; padding: 15px; border: 2px solid #ddd; border-radius: 8px; cursor: pointer; font-weight: bold; background: #f9f9f9; transition: 0.3s; }
        .btn-type.active { border-color: #27ae60; background: #27ae60; color: white; }

        .form-group { margin-bottom: 18px; }
        label { display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px; color: #333; }
        input, select { width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; font-size: 14px; }
        
        .sub-group { background: #f9f9f9; padding: 15px; border-radius: 8px; border-left: 4px solid #27ae60; margin-top: 10px; display: none; }
        .active-block { display: block !important; }

        button[type="submit"] { width: 100%; padding: 15px; background: #2c3e50; color: white; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; margin-top: 20px; }
        button[type="submit"]:disabled { background: #95a5a6; }

        /* Modal Popup */
        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.8); }
        .modal-content { background-color: white; margin: 15% auto; padding: 30px; border-radius: 15px; width: 85%; max-width: 400px; text-align: center; }
        .modal-content h3 { color: #27ae60; margin-top: 0; }
        .bukti-info { background: #f1f8e9; border: 1px dashed #27ae60; padding: 10px; margin-top: 15px; font-size: 13px; }
        .btn-close { margin-top: 20px; padding: 10px 20px; background: #2c3e50; color: white; border: none; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>

<div class="kop-surat">
    <img src="https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhDHJjLxBorbeHLf_Lkx8uBHA9UjQaY7Bpc5z0YZIVr-pAtk3f7snGe-QBFMS4SMbdEVptSO5ZccdTjVIlzZChevMGr_qOZhtwtkqMuQLFlYW916TnCcS6LC2LZo-tXC1Gnw1TXfnYcHK-eAVSd9CU1t3U6WF0ZAIdTNrOZMOCuYfFtv6k1zb8UjKLtyOw/s377/Tanpa%20judul%20(750%20x%20300%20piksel)%20(600%20x%20250%20piksel)%20(1).gif" alt="Kop Surat">
</div>

<div class="container">
    <div class="btn-group">
        <button type="button" class="btn-type" id="btnPPRS" onclick="initLembaga('PPRS')">PPRS (Putra)</button>
        <button type="button" class="btn-type" id="btnPPRM" onclick="initLembaga('PPRM')">PPRM (Putri)</button>
    </div>

    <form id="attendanceForm">
        <input type="hidden" name="lembaga" id="inputLembaga">
        
        <div class="form-group">
            <label>1. Nama Santri</label>
            <input type="text" name="nama_santri" required>
        </div>
        <div class="form-group">
            <label>2. Nama Wali Santri</label>
            <input type="text" name="nama_wali" required>
        </div>
        <div class="form-group">
            <label>3. Alamat (Kota/Kabupaten)</label>
            <input type="text" name="alamat" required placeholder="Contoh:Sawaran Lor - Klakah - Lumajang">
        </div>
        <div class="form-group">
            <label>4. Nomor WhatsApp</label>
            <input type="number" name="no_wa" required placeholder="Contoh: 085258867440">
        </div>

        <div id="dynamicArea" style="display:none">
            <div class="form-group">
                <label>5. Kelas Diniyah</label>
                <select name="kelas_diniyah" id="selectDiniyah" required></select>
            </div>
            <div class="form-group">
                <label>7. Nama Gedung Asrama</label>
                <select id="selectGedung" onchange="updateDetailAsrama()" required></select>
            </div>
            <div class="form-group sub-group" id="subAsramaArea">
                <label id="labelDetailAsrama">Pilih Nomor/Kamar:</label>
                <select name="asrama" id="selectDetailAsrama"></select>
            </div>
        </div>

        <div class="form-group">
            <label>6. Jenjang Formal</label>
            <select id="jenjang" onchange="updateFormalLevel1()">
                <option value="">-- Pilih Jenjang --</option>
                <option value="MI">MI</option><option value="MTs">MTs</option><option value="MA">MA</option><option value="SMK">SMK</option>
            </select>
        </div>

        <div class="form-group sub-group" id="formalLevel1Area">
            <label id="labelLevel1">Pilih Kelas:</label>
            <select id="selectFormalLevel1" onchange="updateFormalLevel2()"></select>
        </div>

        <div class="form-group sub-group" id="formalLevel2Area">
            <label id="labelLevel2">Pilih Huruf/Jurusan:</label>
            <select name="kelas_formal" id="selectFormalLevel2"></select>
        </div>

        <button type="submit" id="btnSubmit">Kirim Kehadiran</button>
        <div id="status" style="text-align:center; margin-top:10px; font-weight:bold;"></div>
    </form>
</div>

<div id="successModal" class="modal">
    <div class="modal-content">
        <h3>BERHASIL! ✅</h3>
        <p>"Terimakasih Anda sudah melakukan daftar hadir Rapat Wali Santri semoga kegiatan ini menjadi tambahan amal ibadah"</p>
        <div class="bukti-info"><strong>Silakan Screenshot layar ini</strong><br>sebagai bukti kehadiran Anda.</div>
        <button type="button" class="btn-close" onclick="closeModal()">Tutup</button>
    </div>
</div>

<script>
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbym-BB_v741iQkn2FQH9C2_Ql9sghxsewkPvFOzLXQmwusjabMCI4FXrZ54GIcovTLnlw/exec"; // <--- TUKAR INI

    const dataOpsi = {
        PPRS: {
            diniyah: ["Shifir","I'dad A4","I'dad A5","I'dad A6","I'dad B1","I'dad B2","1A Ibt","1B Ibt","1C Ibt","1D Ibt","1E Ibt","1F Ibt","1G Ibt","2A Ibt","2B Ibt","2C Ibt","2D Ibt","2E Ibt","3A Ibt","3B Ibt","3C Ibt","3D Ibt","3E Ibt","3F Ibt","4A Ibt","4B Ibt","4C Ibt","4D Ibt","4E Ibt","1A Ts","1B Ts","1C Ts","2A Ts","2B Ts","3 Ts","Aliyah"],
            gedung: ["Al-Hanafi","Al-Maliki","Al-Hambali","As-Syafi'i","LPTQ Jr","LPTQ Sr","Aliyah","Shifir"]
        },
        PPRM: {
            diniyah: ["Sifir A","Sifir B","1A","1B","1C","1D","1E","1F","2A","2B","2C","2D","2E","3A","3B","3C","3D","3E","4A","4B","4C","4D","1A Ts","1B Ts","1C Ts","2A Ts","2B Ts","3A Ts","3B Ts","Aliyah 1","Aliyah 2"],
            gedung: ["Sayyidah Aisyah","Sayyidah Fatimah","Sayyidah Khodijah","Asrama Tahfidz"]
        }
    };

    function initLembaga(type) {
        document.getElementById('inputLembaga').value = type;
        document.getElementById('btnPPRS').classList.toggle('active', type === 'PPRS');
        document.getElementById('btnPPRM').classList.toggle('active', type === 'PPRM');
        document.getElementById('dynamicArea').style.display = 'block';
        
        let d = document.getElementById('selectDiniyah');
        d.innerHTML = '<option value="">-- Pilih Kelas --</option>';
        dataOpsi[type].diniyah.forEach(i => d.innerHTML += `<option value="${i}">${i}</option>`);

        let g = document.getElementById('selectGedung');
        g.innerHTML = '<option value="">-- Pilih Nama Gedung --</option>';
        dataOpsi[type].gedung.forEach(i => g.innerHTML += `<option value="${i}">${i}</option>`);
    }

    function updateDetailAsrama() {
        const gedung = document.getElementById('selectGedung').value;
        const subArea = document.getElementById('subAsramaArea');
        const detail = document.getElementById('selectDetailAsrama');
        detail.innerHTML = "";
        let limit = 0;

        if (["Al-Hanafi","Al-Maliki","Al-Hambali"].includes(gedung)) limit = 8;
        else if (gedung === "As-Syafi'i") limit = 12;
        else if (gedung === "Sayyidah Khodijah") limit = 18;
        else if (gedung === "Asrama Tahfidz") limit = 3;
        else if (gedung === "Sayyidah Aisyah") ["A1","A2","A3","A4","A5","B1","B2","B3","B4","B5"].forEach(v => detail.innerHTML += `<option value="Aisyah ${v}">Aisyah ${v}</option>`);
        else if (gedung === "Sayyidah Fatimah") ["C1","C2","C3","C4","D1","D2","D3","D4"].forEach(v => detail.innerHTML += `<option value="Fatimah ${v}">Fatimah ${v}</option>`);

        if (limit > 0) for(let i=1; i<=limit; i++) detail.innerHTML += `<option value="${gedung} ${i}">${gedung} ${i}</option>`;
        if (detail.innerHTML === "") detail.innerHTML = `<option value="${gedung}">${gedung}</option>`;
        
        subArea.classList.toggle('active-block', !!gedung);
    }

    function updateFormalLevel1() {
        const jenjang = document.getElementById('jenjang').value;
        const area1 = document.getElementById('formalLevel1Area');
        const select1 = document.getElementById('selectFormalLevel1');
        document.getElementById('formalLevel2Area').classList.remove('active-block');
        
        area1.classList.toggle('active-block', !!jenjang);
        select1.innerHTML = '<option value="">-- Pilih Kelas --</option>';

        let opts = [];
        if(jenjang === 'MI') opts = ["1 MI", "2 MI", "3 MI", "4 MI", "5 MI", "6 MI"];
        else if(jenjang === 'MTs') opts = ["Kelas 7", "Kelas 8", "Kelas 9"];
        else if(jenjang === 'MA' || jenjang === 'SMK') opts = ["Kelas X", "Kelas XI", "Kelas XII"];

        opts.forEach(o => select1.innerHTML += `<option value="${o}">${o}</option>`);
    }

    function updateFormalLevel2() {
        const jenjang = document.getElementById('jenjang').value;
        const level1 = document.getElementById('selectFormalLevel1').value;
        const area2 = document.getElementById('formalLevel2Area');
        const select2 = document.getElementById('selectFormalLevel2');
        
        select2.innerHTML = "";
        if (!level1 || jenjang === 'MI') { area2.classList.remove('active-block'); return; }
        area2.classList.add('active-block');

        let opts = [];
        if (jenjang === 'MTs') {
            let huruf = (level1 === "Kelas 8") ? 'ABCDEFGHIJK'.split('') : 'ABCDEFGHIJ'.split('');
            huruf.forEach(h => opts.push(level1 + h));
        } else if (jenjang === 'MA') {
            ["Visikom 1", "Reksa 1", "Kesehatan 1", "Visikom 2", "Reksa 2", "Kesehatan 2", "Tata Boga"].forEach(j => opts.push(level1 + " " + j));
        } else if (jenjang === 'SMK') {
            let jur = (level1 === "Kelas X") ? ["TB", "TKJ 1", "TKJ 2", "TKJ 3", "TKJ 4", "TKR"] : ["TB 1", "TB 2", "TKJ 1", "TKJ 2", "TKJ 3", "TKJ 4", "TKR 1", "TKR 2"];
            jur.forEach(j => opts.push(level1 + " " + j));
        }
        opts.forEach(o => select2.innerHTML += `<option value="${o}">${o}</option>`);
    }

    // FUNGSI PENGHANTARAN KE GOOGLE (GITHUB MODE)
    document.getElementById('attendanceForm').onsubmit = function(e) {
        e.preventDefault();
        const btn = document.getElementById('btnSubmit');
        const stat = document.getElementById('status');
        btn.disabled = true;
        stat.innerHTML = "⏳ Sedang mengirim data...";

        const formData = new FormData(this);
        const params = new URLSearchParams(formData).toString();

        // Menggunakan fetch ke Google Apps Script
        fetch(SCRIPT_URL + "?" + params, {
            method: 'POST'
        })
        .then(() => {
            stat.innerHTML = "";
            document.getElementById('successModal').style.display = 'block';
            this.reset();
            btn.disabled = false;
        })
        .catch(err => {
            console.error(err);
            // Walaupun catch, data biasanya sudah masuk (CORS issue di browser)
            stat.innerHTML = "";
            document.getElementById('successModal').style.display = 'block';
            btn.disabled = false;
        });
    };

    function closeModal() {
        document.getElementById('successModal').style.display = 'none';
        location.reload();
    }
</script>
</body>
</html>
